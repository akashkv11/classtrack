# Option A (recommended): Docker PostgreSQL
# 1. docker compose up -d
# 2. npx prisma migrate dev
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/classtrack?schema=public"

# For hosted Postgres (Neon, Supabase, etc.), use the provider's pooled URL here
# and set DIRECT_URL to the direct/non-pooled connection for migrations.
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/classtrack?schema=public"

APP_PASSWORD="your_secure_password"
SESSION_SECRET="change-this-to-a-long-random-string"
