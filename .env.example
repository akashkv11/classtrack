# Option A (recommended): Docker PostgreSQL
# 1. docker compose up -d
# 2. npx prisma migrate dev
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/classtrack?schema=public"

# Option B: Prisma local dev database
# 1. npx prisma dev -d
# 2. npx prisma db push
# DATABASE_URL is printed by `npx prisma dev ls`
# SHADOW_DATABASE_URL="postgres://postgres:postgres@localhost:51215/template1?sslmode=disable"

APP_PASSWORD="your_secure_password"
SESSION_SECRET="change-this-to-a-long-random-string"
